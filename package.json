{
  "name": "markdown-to-doc",
  "version": "1.0.0",
  "description": "Convert Markdown into a styled DOCX buffer with a single function call.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nilesh9106/markdown-to-doc.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.15.3",
    "jszip": "^3.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "@types/bun": "latest"
  },
  "dependencies": {
    "docx": "^9.5.1",
    "image-size": "^2.0.2",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "bugs": {
    "url": "https://github.com/Nilesh9106/markdown-to-doc/issues"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/Nilesh9106/markdown-to-doc#readme",
  "keywords": [
    "markdown",
    "docx",
    "convert",
    "markdown-to-docx"
  ],
  "license": "MIT",
  "scripts": {
    "build": "bunx --bun tsup src/index.ts --format esm,cjs --dts --clean",
    "example": "bun run examples/markdown-to-docx.ts",
    "test": "bun test",
    "typecheck": "bunx --bun tsc --noEmit",
    "lint": "bunx --bun @biomejs/biome check .",
    "lint:fix": "bunx --bun @biomejs/biome check --write .",
    "format": "bunx --bun @biomejs/biome format --write .",
    "clean": "rm -rf dist",
    "ci:check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "prepublishOnly": "bun run ci:check",
    "publish:npm": "npm publish --access public"
  },
  "sideEffects": false,
  "private": true
}
